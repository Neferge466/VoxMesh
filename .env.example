# ==========================================================================
# VoxMesh Environment Variables
# Copy to .env and adjust values for your deployment.
# ==========================================================================

# --- Database ---
DB_PASSWORD=voxmesh_dev
# DATABASE_URL is auto-constructed from host/port/user above in docker-compose.
# For local dev: postgres://voxmesh:voxmesh_dev@localhost:5432/voxmesh?sslmode=disable

# --- Redis ---
# REDIS_URL is set per-service in docker-compose (redis://redis:6379/<db>).
# For local dev: redis://localhost:6379/0 (DB number varies per service)

# --- EMQX (MQTT Broker) ---
EMQX_ADMIN_PASSWORD=admin123
MQTT_BROKER=tcp://emqx:1883    # Docker; local dev: tcp://localhost:1883

# --- MinIO (Object Storage) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# --- Grafana ---
GRAFANA_PASSWORD=admin

# --- Monitoring (Nginx basic auth for port 8443) ---
MONITOR_USER=admin
MONITOR_PASS=voxmesh_monitor

# --- JWT ---
# Generate keys:
#   openssl genrsa -out secrets/jwt_private.pem 2048
#   openssl rsa -in secrets/jwt_private.pem -pubout -out secrets/jwt_public.pem
JWT_PRIVATE_KEY=./secrets/jwt_private.pem
JWT_PUBLIC_KEY=./secrets/jwt_public.pem

# --- CORS ---
# Comma-separated extra origins for browser access (e.g. LAN IP).
CORS_ORIGINS=

# --- Logging ---
# LOG_FORMAT=json   # JSON output for production
# LOG_LEVEL=debug   # debug|info|warn|error (default: info)

# --- Service URLs (Docker internal — override for local dev) ---
AUTH_SERVICE_URL=http://auth-service:8080          # local: http://localhost:8081
CHANNEL_SERVICE_URL=http://channel-service:8080     # local: http://localhost:8082
AUDIO_MIXER_ADDR=audio-mixer:9000                  # local: localhost:9000

# --- MQTT Client IDs (per service) ---
MQTT_CLIENT_ID_CHANNEL=svc_channel
MQTT_CLIENT_ID_AUDIO_MIXER=svc_audio_mixer
MQTT_CLIENT_ID_PRESENCE=svc_presence
MQTT_CLIENT_ID_GATEWAY_COORD=svc_gateway_coord
MQTT_CLIENT_ID_COMMAND=svc_command
MQTT_CLIENT_ID_NOTIFICATION=svc_notification

# --- TURN Server (WebRTC NAT traversal) ---
TURN_SECRET=voxmesh-turn-dev-secret-change-me
TURN_EXTERNAL_IP=auto

# --- SFU (LiveKit — for 4+ user channels) ---
LIVEKIT_KEYS=devkey: secret
LIVEKIT_HOST=

# --- Backup ---
BACKUP_DIR=./backups
RETENTION_DAYS=30
